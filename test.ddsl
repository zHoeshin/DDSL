eyn = {
	neutral = ^"res://eyn1.png",
	happy = ^"res://eyn2.png",
	lid = ^"res://eyn3.png",
	test = ^"res://eyn.png",
}

#print(eyn.test)
#printerr("done")
eyn.neutral: "..."
eyn.neutral: "So who even are you?"
eyn.neutral: "I don't know if I'd rather believe you're the God, or I am going insane anymore."
$god = false
<- options
- "I AM God"
	eyn.lid: "Oh, REALLY? And how am I supposed to believe in that?"
	eyn.neutral: "Come on, do something oh-so-godly to convince me"
	wait(3)
	eyn.lid: "..."
	$god = true
- "You ARE going insane"
	eyn.lid: "Figures."
- "It's irrelevant"
	eyn.neutral: "Sure as hell not unimportant, then."
eyn.neutral: "Whatever."

eyn.neutral: "Where are 'we' anyways?"
<- options
- "It's a lab"
	eyn.lid: "A lab? What kinda lab?"
	eyn.neutral: "All I see is gray nothing. Is there even a celing here?"
- "I don't know"
	eyn.neutral: "So what are we going to do?"
	? $god
		eyn.neutral: "Besides... Aren't gods supposed to be all knowing?"

$nothing = false
$npceyn.animate.walk(Vector2i(1, 0))
eyn.neutral: "You think there's anything here?"
<- options
- "Yes"
	eyn.happy: "Really? What?"
	wait(1)
	eyn.lid: "...sigh"
	wait(15)
- "Probably"
	eyn.neutral: "Not like I have anything better to do"
	wait(15)
- "No"
	eyn.neutral: "Are you sure about that?"
	$nothing = true
	wait(4)
--
	eyn.lid: "...sigh"
	wait(15)

$npceyn.move(Vector2i(32, 0))
await $npceyn.stop
$npceyn.animate.stop()
$npceyn.animate.turn(Vector2i(0, -1))
? $nothing
	eyn.happy: "Hey, you're wrong. There IS something here."
?!
	eyn.neutral: "Hey, there IS something here."
$npceyn.animate.walk(Vector2i(-1, 0))
$npceyn.move(Vector2i(-8, 0))
await $npceyn.stop()
$npceyn.animate.stop()
eyn.neutral: "I wonder what this is"
